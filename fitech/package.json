{
  "name": "fitech",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "generate_apk": "npx eas-cli build --platform android --profile apk",
    "generate:android-icon": "npx --yes -p sharp node scripts/generate-android-adaptive-icon.mjs",
    "generate:android-notification-icon": "npx --yes -p sharp node scripts/generate-android-notification-icon.mjs",
    "generate_ios": "npx eas-cli build --platform ios --profile production",
    "generate_ios_autosubmit": "npx eas-cli build --platform ios --profile production --auto-submit",
    "submit_ios": "npx eas-cli submit --platform ios --latest",
    "codegen": "openapi-ts --file openapi/fitech.config.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint:fix": "npx eslint . --fix"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.3.0",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^4.4.5",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/drawer": "^7.1.1",
    "@react-navigation/material-top-tabs": "^7.2.13",
    "@react-navigation/native": "^7.0.14",
    "@tanstack/react-query": "^5.77.2",
    "expo": "^54",
    "expo-application": "~7.0.8",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "lodash": "^4.17.21",
    "lottie-react-native": "~7.3.1",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1313.0",
    "react-native-dropdown-picker": "^5.4.6",
    "react-native-element-dropdown": "^2.12.4",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-pager-view": "6.9.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-tab-view": "^4.1.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-vector-icons": "^10.2.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "ubigeo-fns": "^2.2.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@hey-api/openapi-ts": "^0.77.0",
    "@types/jest": "^29.5.12",
    "@types/moment-timezone": "^0.5.30",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "~19.1.0",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.4.2",
    "eslint-plugin-expo": "^1.0.3",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jest": "^29.2.1",
    "jest-expo": "~54.0.17",
    "prettier": "^3.5.3",
    "react-native-svg-transformer": "^1.5.1",
    "react-test-renderer": "19.1.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2"
  },
  "private": true,
  "overrides": {
    "react-native-calendars": {
      "react-native-safe-area-context": "$react-native-safe-area-context"
    },
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@typescript-eslint/typescript-estree": "^8.46.0",
    "@typescript-eslint/utils": "^8.46.0",
    "@typescript-eslint/type-utils": "^8.46.0",
    "@types/react-test-renderer": {
      "@types/react": "$@types/react"
    }
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "react-native-keyboard-aware-scroll-view",
          "react-native-dropdown-picker",
          "expo-crypto",
          "moment",
          "moment-timezone",
          "react-native-vector-icons",
          "ubigeo-fns"
        ]
      }
    }
  }
}
